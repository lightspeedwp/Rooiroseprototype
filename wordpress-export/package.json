{
  "name": "die-papier-wordpress-project",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "WordPress migration project for Die Papier",
  "scripts": {
    "setup": "npm install && cd plugins/die-papier-blocks && npm install",
    "build:plugin": "cd plugins/die-papier-blocks && npm run build",
    "start:plugin": "cd plugins/die-papier-blocks && npm run start",
    "export:content": "node scripts/generate-wxr.js"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "xmlbuilder2": "^3.1.1",
    "glob": "^10.3.10"
  }
}