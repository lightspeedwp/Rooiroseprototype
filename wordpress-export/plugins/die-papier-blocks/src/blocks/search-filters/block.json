{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "dp/search-filters",
	"version": "1.0.0",
	"title": "Soekfilters",
	"category": "die-papier",
	"icon": "search",
	"description": "Soekresultate-filterkontroles (datum, kategorie, sorteer). Vorm-indiening lei tot herlaaing met navraagparameters.",
	"textdomain": "die-papier-blocks",
	"keywords": [ "search", "soek", "filters", "sort", "category" ],
	"attributes": {
		"showDate": {
			"type": "boolean",
			"default": true
		},
		"showCategory": {
			"type": "boolean",
			"default": true
		},
		"showSort": {
			"type": "boolean",
			"default": true
		}
	},
	"supports": {
		"align": [ "wide" ],
		"html": false,
		"interactivity": true,
		"anchor": true
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"viewScriptModule": "file:./view.js"
}