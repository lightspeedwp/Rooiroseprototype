{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "dp/weather-widget",
	"version": "1.0.0",
	"title": "Weer Widget",
	"category": "die-papier",
	"icon": "cloud",
	"description": "Weer-legstuk met stadkieser. Bediener-gerendeer met kliëntsy-hidrasie vir lewendige opdaterings.",
	"textdomain": "die-papier-blocks",
	"keywords": [ "weather", "weer", "temperature", "temperatuur", "forecast" ],
	"attributes": {
		"location": {
			"type": "string",
			"default": "Paarl"
		},
		"showForecast": {
			"type": "boolean",
			"default": true
		},
		"apiEndpoint": {
			"type": "string",
			"default": ""
		}
	},
	"supports": {
		"align": [ "wide", "full" ],
		"html": false,
		"interactivity": true,
		"anchor": true
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"viewScriptModule": "file:./view.js"
}