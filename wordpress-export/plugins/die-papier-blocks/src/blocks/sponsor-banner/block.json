{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "dp/sponsor-banner",
	"version": "1.0.0",
	"title": "Borg Banner",
	"category": "die-papier",
	"icon": "megaphone",
	"description": "Vertoon 'n enkele borg-logo en skakel, dinamies gehaal uit die dp_sponsor CPT.",
	"keywords": [ "sponsor", "borg", "logo", "banner", "vennoot" ],
	"attributes": {
		"sponsorId": {
			"type": "number",
			"default": 0
		},
		"alignment": {
			"type": "string",
			"default": "center",
			"enum": [ "left", "center", "right" ]
		},
		"size": {
			"type": "string",
			"default": "medium",
			"enum": [ "small", "medium", "large" ]
		}
	},
	"supports": {
		"align": [ "full", "wide" ],
		"html": false,
		"spacing": {
			"margin": true,
			"padding": true
		},
		"color": {
			"background": true,
			"text": false
		}
	},
	"textdomain": "die-papier-blocks",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}