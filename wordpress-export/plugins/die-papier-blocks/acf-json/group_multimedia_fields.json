{
  "key": "group_dp_multimedia",
  "title": "Multimedia Velde",
  "fields": [
    {
      "key": "field_multimedia_type",
      "label": "Media Tipe",
      "name": "media_type",
      "type": "select",
      "required": 1,
      "choices": {
        "Video": "Video",
        "Fotogalery": "Fotogalery",
        "Podcast": "Podcast"
      },
      "default_value": "Video",
      "instructions": "Die tipe multimedia-inhoud."
    },
    {
      "key": "field_multimedia_duration",
      "label": "Duur",
      "name": "duration",
      "type": "text",
      "required": 0,
      "placeholder": "12:34",
      "instructions": "Lengte van die video of podcast-episode."
    },
    {
      "key": "field_multimedia_video_url",
      "label": "Video URL",
      "name": "video_url",
      "type": "url",
      "required": 0,
      "instructions": "YouTube, Vimeo of ander video-skakel.",
      "conditional_logic": [
        [
          {
            "field": "field_multimedia_type",
            "operator": "==",
            "value": "Video"
          }
        ]
      ]
    },
    {
      "key": "field_multimedia_podcast_url",
      "label": "Podcast URL",
      "name": "podcast_url",
      "type": "url",
      "required": 0,
      "instructions": "Podcast-episode skakel (Spotify, Apple Podcasts, ens.).",
      "conditional_logic": [
        [
          {
            "field": "field_multimedia_type",
            "operator": "==",
            "value": "Podcast"
          }
        ]
      ]
    },
    {
      "key": "field_multimedia_photo_gallery",
      "label": "Fotogalery",
      "name": "photo_gallery",
      "type": "gallery",
      "required": 0,
      "return_format": "array",
      "preview_size": "medium",
      "min": 0,
      "max": 50,
      "instructions": "Laai foto's vir die galery op.",
      "conditional_logic": [
        [
          {
            "field": "field_multimedia_type",
            "operator": "==",
            "value": "Fotogalery"
          }
        ]
      ]
    },
    {
      "key": "field_multimedia_photo_count",
      "label": "Foto-telling",
      "name": "photo_count",
      "type": "number",
      "required": 0,
      "instructions": "Word outomaties bereken uit die galery, maar kan oorgeskryf word."
    },
    {
      "key": "field_multimedia_episode_number",
      "label": "Episode Nommer",
      "name": "episode_number",
      "type": "text",
      "required": 0,
      "placeholder": "S2E15",
      "instructions": "Episode-nommer of seisoen-episode formaat."
    },
    {
      "key": "field_multimedia_views",
      "label": "Kyke",
      "name": "views",
      "type": "number",
      "required": 0,
      "default_value": 0,
      "instructions": "Totale kyke/luisterings."
    }
  ],
  "location": [
    [
      {
        "param": "post_type",
        "operator": "==",
        "value": "dp_multimedia"
      }
    ]
  ],
  "menu_order": 0,
  "position": "normal",
  "style": "default",
  "label_placement": "top",
  "instruction_placement": "label",
  "active": true,
  "show_in_rest": 1
}
