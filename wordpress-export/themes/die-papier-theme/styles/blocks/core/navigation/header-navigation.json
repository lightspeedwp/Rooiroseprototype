{
	"$schema": "https://schemas.wp.org/wp/6.8/theme.json",
	"version": 3,
	"title": "Header Navigation",
	"slug": "header-navigation",
	"blockTypes": ["core/navigation"],
	"styles": {
		"typography": {
			"textTransform": "uppercase",
			"letterSpacing": "1px",
			"fontSize": "var:preset|font-size|base",
			"fontWeight": "600",
			"textDecoration": "none"
		},
		"color": {
			"text": "var:preset|color|main"
		},
		"css": "& .wp-block-navigation-item a.wp-block-navigation-item__content{text-decoration:none !important;color:var(--wp--preset--color--main) !important;transition:color 0.15s ease;} & .wp-block-navigation-item a.wp-block-navigation-item__content:hover{color:var(--wp--preset--color--primary-alt) !important;text-decoration:none !important;}"
	}
}
