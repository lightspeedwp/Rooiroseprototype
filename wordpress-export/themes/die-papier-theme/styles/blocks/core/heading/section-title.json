{
	"$schema": "https://schemas.wp.org/wp/6.8/theme.json",
	"version": 3,
	"title": "Section Title",
	"slug": "section-title",
	"blockTypes": ["core/heading"],
	"styles": {
		"typography": {
			"fontFamily": "var:preset|font-family|brand-sans",
			"textTransform": "uppercase",
			"letterSpacing": "0.15em",
			"fontSize": "0.875rem",
			"fontWeight": "700"
		},
		"color": {
			"text": "var:preset|color|main-accent"
		},
		"border": {
			"bottom": {
				"color": "var:preset|color|primary",
				"width": "2px",
				"style": "solid"
			}
		},
		"spacing": {
			"padding": {
				"bottom": "var:preset|spacing|x-small"
			}
		}
	}
}
