{
	"$schema": "https://schemas.wp.org/wp/6.8/theme.json",
	"version": 3,
	"title": "Branded",
	"slug": "branded",
	"blockTypes": ["core/query-pagination"],
	"styles": {
		"blocks": {
			"core/query-pagination-numbers": {
				"css": "&{display:flex;flex-wrap:wrap;} & .page-numbers{text-decoration:none !important;padding:var(--wp--preset--spacing--x-small) var(--wp--preset--spacing--small);border-radius:var(--wp--custom--border-radius--400);border:var(--wp--custom--border-width--100) solid var(--wp--preset--color--border-light);background-color:var(--wp--preset--color--base);color:var(--wp--preset--color--secondary) !important;transition:border-color 0.15s ease, color 0.15s ease;} & .page-numbers.current{background-color:var(--wp--preset--color--primary);color:var(--wp--preset--color--base) !important;border-color:var(--wp--preset--color--primary);} & a.page-numbers:hover{border-color:var(--wp--preset--color--primary);color:var(--wp--preset--color--primary) !important;text-decoration:none !important;}"
			},
			"core/query-pagination-previous": {
				"typography": {
					"textDecoration": "none"
				},
				"color": {
					"text": "var:preset|color|primary",
					"background": "var:preset|color|base"
				},
				"border": {
					"width": "var:custom|border-width|200",
					"color": "var:preset|color|primary",
					"style": "solid",
					"radius": "var:custom|border-radius|400"
				},
				"spacing": {
					"padding": {
						"top": "var:preset|spacing|x-small",
						"bottom": "var:preset|spacing|x-small",
						"left": "var:preset|spacing|small",
						"right": "var:preset|spacing|small"
					}
				},
				"css": "&:hover{background-color:var(--wp--preset--color--primary);color:var(--wp--preset--color--base) !important;border-color:var(--wp--preset--color--primary);text-decoration:none !important;}"
			},
			"core/query-pagination-next": {
				"typography": {
					"textDecoration": "none"
				},
				"color": {
					"text": "var:preset|color|primary",
					"background": "var:preset|color|base"
				},
				"border": {
					"width": "var:custom|border-width|200",
					"color": "var:preset|color|primary",
					"style": "solid",
					"radius": "var:custom|border-radius|400"
				},
				"spacing": {
					"padding": {
						"top": "var:preset|spacing|x-small",
						"bottom": "var:preset|spacing|x-small",
						"left": "var:preset|spacing|small",
						"right": "var:preset|spacing|small"
					}
				},
				"css": "&:hover{background-color:var(--wp--preset--color--primary);color:var(--wp--preset--color--base) !important;border-color:var(--wp--preset--color--primary);text-decoration:none !important;}"
			}
		}
	}
}
