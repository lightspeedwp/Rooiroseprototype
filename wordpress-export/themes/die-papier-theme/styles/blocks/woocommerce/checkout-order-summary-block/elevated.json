{
	"$schema": "https://schemas.wp.org/wp/6.8/theme.json",
	"version": 3,
	"title": "Elevated",
	"slug": "elevated",
	"blockTypes": ["woocommerce/checkout-order-summary-block"],
	"styles": {
		"border": {
			"color": "var:preset|color|border-light",
			"width": "1px",
			"radius": "var(--wp--custom--border-radius--300)"
		},
		"shadow": "var(--wp--preset--shadow--400)",
		"spacing": {
			"padding": {
				"top": "var:preset|spacing|large",
				"right": "var:preset|spacing|large",
				"bottom": "var:preset|spacing|large",
				"left": "var:preset|spacing|large"
			},
			"blockGap": "var:preset|spacing|medium"
		}
	}
}
