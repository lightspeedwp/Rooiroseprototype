{
	"$schema": "https://schemas.wp.org/wp/6.8/theme.json",
	"version": 3,
	"styles": {
		"blocks": {
			"core/site-title": {
				"typography": {
					"fontFamily": "var:preset|font-family|brand-serif",
					"fontWeight": "700",
					"letterSpacing": "-0.5px"
				},
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						},
						":hover": {
							"typography": {
								"textDecoration": "underline"
							}
						}
					}
				}
			}
		}
	}
}
