{
	"$schema": "https://schemas.wp.org/wp/6.8/theme.json",
	"version": 3,
	"settings": {
		"blocks": {
			"outermost/social-sharing": {
				"color": {
					"palette": [
						{ "slug": "secondary", "color": "var(--wp--preset--color--secondary)", "name": "Navy" },
						{ "slug": "primary", "color": "var(--wp--preset--color--primary)", "name": "Red" },
						{ "slug": "white", "color": "var(--wp--preset--color--base)", "name": "White" }
					]
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--brand-sans)",
					"fontSize": "var(--wp--preset--font-size--small)"
				},
				"spacing": {
					"blockGap": "var(--wp--preset--spacing--small)"
				}
			}
		}
	}
}
